# Copy to .env for local overrides (do not commit .env)

# Docker Hub (GitHub Actions CI/CD)
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token

# AWS EKS (GitHub Actions CD — set as GitHub Secrets)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-central-1
EKS_CLUSTER_NAME=your-eks-cluster-name

# PostgreSQL (docker-compose defaults)
POSTGRES_DB=student_db
POSTGRES_USER=sms_user
POSTGRES_PASSWORD=sms_pass

# Backend (docker-compose overrides these automatically)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/student_db
SPRING_DATASOURCE_USERNAME=sms_user
SPRING_DATASOURCE_PASSWORD=sms_pass
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
